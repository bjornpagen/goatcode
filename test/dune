(library
 (name goatcode_test)
 ; Probe files (probe_*.ml) are NOT modules of this library: the negative
 ; ones must not typecheck, so they are compiled (and required to fail) by
 ; the rules below.
 (modules
  test_goatcode
  test_engine
  test_delivery
  test_squash
  test_witness
  test_disjoint
  test_landing
  test_frontier
  test_drift
  test_boundary
  test_heads
  test_admission
  test_report
  test_fiber
  test_mount
  test_probes)
 ; The preview ppx_expect on this switch resolves source files relative to
 ; the runner's cwd (the library dir), not the workspace root that dune's
 ; backend flags pass as -source-tree-root; the trailing flag wins.
 (inline_tests
  (flags -source-tree-root .))
 ; unix: falsifier F4 instruments the settlement-to-issue path (stderr
 ; capture via dup2, ledger-file stat); F1 bounds real wall clock; F9's
 ; churn-evidence construction uses millisecond sleeps for
 ; strictly-increasing ledger timestamps; FB7's poll-pumped loopback
 ; server (the genuinely-multi curl falsifier's peer — single-threaded,
 ; because the scheduler under test owns the only domain).
 (libraries goatcode yojson unix)
 (preprocess
  (pps ppx_expect)))

; --- F15: compile-time probes (docs/architecture/80-validation.md) ---------
;
; Each negative probe is a program that must NOT typecheck. The rule
; compiles it with the same command as the control, accepts ONLY the
; compiler's error exit (2) — an unexpected successful compile fails the
; rule, going red exactly when an "unrepresentable" state becomes
; representable — and a second rule greps the captured diagnostic for the
; expected error class, so a probe cannot "pass" by failing for an
; unrelated reason (e.g. a broken include path).
;
; (sandbox none): the probes compile against the library's cmis in
; ../lib/.goatcode.objs/byte, materialized by depending on goatcode.cma.

; The harness control: MUST compile. If this rule fails, every negative
; probe is failing for a spurious reason.

(rule
 (targets probe_control.cmi probe_control.cmo)
 (deps
  (sandbox none)
  probe_control.ml
  ../lib/goatcode.cma)
 (action
  (run ocamlfind ocamlc -package yojson -I ../lib/.goatcode.objs/byte -c
    probe_control.ml)))

(rule
 (alias runtest)
 (deps probe_control.cmo)
 (action (progn)))

; F15 probe: wrong-relation phantom ref (20-contracts.md § failure surface).

(rule
 (targets probe_f15_wrong_relation_ref.err)
 (deps
  (sandbox none)
  probe_f15_wrong_relation_ref.ml
  ../lib/goatcode.cma)
 (action
  (with-accepted-exit-codes
   2
   (with-stderr-to
    probe_f15_wrong_relation_ref.err
    (run ocamlfind ocamlc -package yojson -I ../lib/.goatcode.objs/byte -c
      probe_f15_wrong_relation_ref.ml)))))

(rule
 (alias runtest)
 (deps probe_f15_wrong_relation_ref.err)
 (action
  (run grep -q "is not compatible with type"
    probe_f15_wrong_relation_ref.err)))

